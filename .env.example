DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proof_of_work?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/proof_of_work?schema=public"

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

MASTER_KEY="base64-32-byte-key"
REDIS_URL="redis://localhost:6379"

# Queue backend: bull (default) or supabase
SYNC_QUEUE_BACKEND="bull"

# Required only for Supabase queue cron processor endpoint
CRON_SECRET="change-me"

APP_URL="http://localhost:3000"
# Optional client-side override for Supabase magic-link redirect destination.
# Use in local dev to force localhost callback:
# NEXT_PUBLIC_AUTH_REDIRECT_URL="http://localhost:3000"
